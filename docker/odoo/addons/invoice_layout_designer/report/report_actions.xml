<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Paper format: let our CSS @page handle margins, so wkhtmltopdf
         doesn't add its own margins on top. -->
    <record id="paperformat_ild_custom" model="report.paperformat">
        <field name="name">ILD Custom Layout</field>
        <field name="format">A4</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_spacing">0</field>
        <field name="dpi">96</field>
        <field name="disable_shrinking" eval="True"/>
    </record>

    <!-- Custom document report action -->
    <record id="action_report_custom_document" model="ir.actions.report">
        <field name="name">Custom Layout Document</field>
        <field name="model">account.move</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">invoice_layout_designer.report_custom_document</field>
        <field name="report_file">invoice_layout_designer.report_custom_document</field>
        <field name="print_report_name">'Document_%s' % object.name</field>
        <field name="binding_model_id" ref="account.model_account_move"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_ild_custom"/>
    </record>
</odoo>
